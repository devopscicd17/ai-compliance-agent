# ─────────────────────────────────────────────
#  AWS Compliance Agent — Environment Config
# ─────────────────────────────────────────────

# AWS Credentials (leave blank to use instance role / AWS CLI profile)
AWS_ACCESS_KEY_ID=AKIA3XVUIG3CHLD65LYW
AWS_SECRET_ACCESS_KEY=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
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_PROFILE=default

# Multi-account scanning (comma-separated account IDs, leave blank for current account)
AWS_TARGET_ACCOUNTS=
# IAM role to assume in each target account (cross-account scanning)
AWS_ASSUME_ROLE_NAME=ComplianceAgentRole

# Anthropic API key for AI-powered analysis and remediation
ANTHROPIC_API_KEY=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

# Active compliance frameworks (comma-separated)
# Options: FEDRAMP,CIS,NIST,PCI,CUSTOM
ACTIVE_FRAMEWORKS=FEDRAMP,CIS,NIST

# Severity threshold for auto-remediation (CRITICAL, HIGH, MEDIUM, LOW)
AUTO_REMEDIATE_THRESHOLD=CRITICAL
# Safety mode: DRY_RUN won't apply changes, ACTIVE will
REMEDIATION_MODE=DRY_RUN

# Report output
REPORT_OUTPUT_DIR=./reports
REPORT_FORMATS=HTML,JSON,PDF

# Notifications (optional)
SNS_TOPIC_ARN=
SLACK_WEBHOOK_URL=

# Scan schedule (cron syntax, for watch mode)
SCAN_INTERVAL_MINUTES=60

# Custom policy file path
CUSTOM_POLICY_FILE=./config/custom-policies.json
